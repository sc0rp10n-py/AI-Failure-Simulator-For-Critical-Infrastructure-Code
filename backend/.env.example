FLASK_ENV=development
SENTINEL_DB_PATH=./data/sentinel.db
SENTINEL_UPLOAD_ROOT=./uploads
SENTINEL_OUTPUT_ROOT=./outputs
SENTINEL_DEMO_ROOT=..
SENTINEL_SESSION_SECRET=change-me-in-production
SENTINEL_CORS_ORIGINS=http://localhost:1000

# LLM: heuristic | ollama
# SENTINEL_LLM_PROVIDER=heuristic

# Local Ollama
# SENTINEL_OLLAMA_BASE_URL=http://localhost:11434
# SENTINEL_OLLAMA_MODEL=gemma2:2b

# Ollama Cloud (https://ollama.com/settings/keys)
SENTINEL_LLM_PROVIDER=ollama
SENTINEL_OLLAMA_BASE_URL=https://ollama.com
SENTINEL_OLLAMA_MODEL=gemma3:27b-cloud
# SENTINEL_OLLAMA_API_KEY=your_key_here

# Dockerized sandbox settings
SENTINEL_SANDBOX_ENABLED=true
SENTINEL_SANDBOX_PREFER_DOCKER=true
SENTINEL_SANDBOX_USE_COMPOSE=true
SENTINEL_SANDBOX_READY_TIMEOUT=90
SENTINEL_SANDBOX_INSTALL_TIMEOUT=180
